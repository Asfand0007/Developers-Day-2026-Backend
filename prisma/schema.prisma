generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                           String                  @id @default(uuid())
  email                        String                  @unique @db.VarChar(255)
  password                     String?                 @db.VarChar(255)
  isActive                     Boolean                 @default(true)
  lastLogin                    DateTime?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  type                         UserType                @default(PARTICIPANT)
  brandAmbassador              BrandAmbassador?
  company                      Company?
  markedCompetitionAttendances CompetitionAttendance[] @relation("AttendanceMarkedBy")
  foodStall                    FoodStall?
  participant                  Participant?
  staffProfile                 StaffProfile?
  actionsGrantedByMe           UserAction[]            @relation("ActionGrantedBy")
  grantedActions               UserAction[]            @relation("UserGrantedActions")

  @@index([email])
  @@index([type])
}

model Participant {
  id                     String                  @id @default(uuid())
  userId                 String                  @unique
  cnic                   String?                 @unique @db.VarChar(15)
  email                  String                  @unique @db.VarChar(255)
  fullName               String                  @db.VarChar(100)
  phone                  String?                 @db.VarChar(20)
  institution            String?                 @db.VarChar(200)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  rollNumber             String?                 @db.VarChar(20)
  minigameCode           String?                 @unique @db.VarChar(20)
  competitionAttendances CompetitionAttendance[]
  activityCompletions    ParticipantActivityCompletion[]
  activitySubmissions    ActivitySubmission[]
  pointsLedgerEntries    PointsLedger[]
  pointsSummary          PointsSummary?
  scores                 Score[]
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMembers            TeamMember[]

  @@index([cnic])
  @@index([email])
}

model Activity {
  id          String                          @id @default(uuid())
  code        String                          @unique @db.VarChar(50)
  name        String                          @db.VarChar(100)
  description String?
  points      Int
  activityTypeId String
  correctAnswerCanonical String?              @db.VarChar(300)
  isActive    Boolean                         @default(true)
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @updatedAt
  createdByStaffProfileId String?
  updatedByStaffProfileId String?
  completions ParticipantActivityCompletion[]
  submissions ActivitySubmission[]
  type        ActivityType                    @relation(fields: [activityTypeId], references: [id], onDelete: Restrict)
  createdBy   StaffProfile?                   @relation("ActivityCreatedBy", fields: [createdByStaffProfileId], references: [id], onDelete: SetNull)
  updatedBy   StaffProfile?                   @relation("ActivityUpdatedBy", fields: [updatedByStaffProfileId], references: [id], onDelete: SetNull)

  @@index([activityTypeId])
  @@index([isActive])
}

model ActivityType {
  id          String   @id @default(uuid())
  /// Built-in codes include MANUAL, LINK_BASED, CORRECT_ANSWER, MANUAL_TEXT_SUBMISSION.
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities  Activity[]

  @@index([isActive])
}

model ParticipantActivityCompletion {
  id            String        @id @default(uuid())
  participantId String
  activityId    String
  submissionLink String?
  completedAt   DateTime      @default(now())
  markedByStaffProfileId String
  note          String?
  participant   Participant   @relation(fields: [participantId], references: [id], onDelete: Cascade)
  activity      Activity      @relation(fields: [activityId], references: [id], onDelete: Restrict)
  markedBy      StaffProfile  @relation("ActivityCompletionMarkedBy", fields: [markedByStaffProfileId], references: [id], onDelete: Restrict)
  ledgerEntries PointsLedger[]

  @@unique([participantId, activityId])
  @@index([participantId])
  @@index([activityId])
  @@index([markedByStaffProfileId])
}

model ActivitySubmission {
  id                      String           @id @default(uuid())
  participantId           String
  activityId              String
  submissionLink          String?
  submissionText          String?          @db.VarChar(300)
  status                  SubmissionStatus @default(PENDING)
  submittedAt             DateTime         @default(now())
  reviewedAt              DateTime?
  reviewedByStaffProfileId String?
  reviewNote              String?
  participant             Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  activity                Activity         @relation(fields: [activityId], references: [id], onDelete: Restrict)
  reviewedBy              StaffProfile?    @relation("ActivitySubmissionReviewedBy", fields: [reviewedByStaffProfileId], references: [id], onDelete: SetNull)

  @@index([participantId])
  @@index([activityId])
  @@index([status, submittedAt])
}

model SignupOtpLink {
  id          String   @id @default(uuid())
  email       String   @db.VarChar(255)
  fullName    String?  @db.VarChar(100)
  tokenHash   String   @unique @db.VarChar(128)
  expiresAt   DateTime
  consumedAt  DateTime?
  requestedIp String?  @db.VarChar(64)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email, createdAt])
  @@index([expiresAt])
}

model MasterConfig {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(100)
  valueText   String?  @db.VarChar(255)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompetitionConfig {
  id            String      @id @default(uuid())
  competitionId String
  key           String      @db.VarChar(100)
  valueText     String?     @db.VarChar(255)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([competitionId, key])
  @@index([key])
}

model PointsLedger {
  id                 String                   @id @default(uuid())
  participantId      String
  entryType          PointsLedgerEntryType
  pointsDelta        Int
  sourceCompletionId String?
  actorStaffProfileId String
  metadata           Json?
  createdAt          DateTime                 @default(now())
  participant        Participant              @relation(fields: [participantId], references: [id], onDelete: Cascade)
  sourceCompletion   ParticipantActivityCompletion? @relation(fields: [sourceCompletionId], references: [id], onDelete: SetNull)
  actor              StaffProfile             @relation("PointsLedgerActor", fields: [actorStaffProfileId], references: [id], onDelete: Restrict)

  @@unique([sourceCompletionId])
  @@index([participantId, createdAt])
  @@index([entryType])
  @@index([actorStaffProfileId])
}

model PointsSummary {
  participantId String      @id
  totalPoints   Int         @default(0)
  updatedAt     DateTime    @updatedAt
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([totalPoints])
}

model PointsAuditLog {
  id         String               @id @default(uuid())
  actorStaffProfileId String
  actionType PointsAuditActionType
  targetType String?              @db.VarChar(50)
  targetId   String?
  note       String?
  payload    Json?
  createdAt  DateTime             @default(now())
  actor      StaffProfile         @relation("PointsAuditActor", fields: [actorStaffProfileId], references: [id], onDelete: Restrict)

  @@index([actorStaffProfileId, createdAt])
  @@index([actionType, createdAt])
}

model Competition {
  id                   String    @id @default(uuid())
  name                 String    @db.VarChar(100)
  description          String    @default("-")
  fee                  Decimal   @default(0) @db.Decimal(10, 2)
  minTeamSize          Int       @default(1)
  maxTeamSize          Int
  capacityLimit        Int
  compDay              DateTime  @db.Date
  startTime            DateTime
  endTime              DateTime
  isActive             Boolean   @default(true)
  registrationDeadline DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  category             String?
  ruleBookUrl          String?
  earlyBirdFee         Decimal   @default(0) @db.Decimal(10, 2)
  earlyBirdLimit       Int       @default(0)
  configs              CompetitionConfig[]
  teams                Team[]
  venues               Venue[]   @relation("CompetitionToVenue")
  totalSeats           Int       @default(0)

  @@index([compDay])
  @@index([isActive])
}

model Team {
  id              String                  @id @default(uuid())
  competitionId   String
  name            String                  @db.VarChar(100)
  referenceId     String                  @db.VarChar(50)
  paymentStatus   RegistrationStatus      @default(PENDING_PAYMENT)
  paymentProofUrl String?                 @db.VarChar(500)
  paymentMethod   PaymentMethod?
  paymentDate     DateTime?
  declaredTID     String?                 @db.VarChar(100)
  amountPaid      Decimal?                @db.Decimal(10, 2)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  isEarlyBird     Boolean                 @default(false)
  attendance      CompetitionAttendance[]
  competition     Competition             @relation(fields: [competitionId], references: [id])
  members         TeamMember[]
  @@index([competitionId])
  @@index([paymentStatus])
  @@index([referenceId])
}

model TeamMember {
  id            String      @id @default(uuid())
  teamId        String
  participantId String
  isLeader      Boolean     @default(false)
  joinedAt      DateTime    @default(now())
  cardIssued    Boolean     @default(false)
  cardIssuedAt  DateTime?
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  team          Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamEmailsQueue  TeamEmailsQueue[]
  @@unique([teamId, participantId])
  @@index([teamId])
  @@index([participantId])
}

model CompetitionAttendance {
  id             String           @id @default(uuid())
  teamId         String
  participantId  String
  status         Boolean          @default(false)
  method         AttendanceMethod
  markedAt       DateTime         @default(now())
  notes          String?
  /// Replaces markedBy string with a real relation to the portal user (staff).
  markedByUserId String?
  markedByUser   User?            @relation("AttendanceMarkedBy", fields: [markedByUserId], references: [id])
  participant    Participant      @relation(fields: [participantId], references: [id])
  team           Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, participantId])
  @@index([teamId])
  @@index([participantId])
  @@index([markedAt])
  @@index([markedByUserId])
}

model StaffProfile {
  id            String    @id
  fullName      String    @db.VarChar(100)
  nuId          String    @unique @db.VarChar(20)
  isApproved    Boolean   @default(false)
  approvedAt    DateTime?
  assignedBooth String?   @db.VarChar(50)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  staffRole     StaffRole
  createdActivities         Activity[]                      @relation("ActivityCreatedBy")
  updatedActivities         Activity[]                      @relation("ActivityUpdatedBy")
  markedActivityCompletions ParticipantActivityCompletion[] @relation("ActivityCompletionMarkedBy")
  reviewedActivitySubmissions ActivitySubmission[]          @relation("ActivitySubmissionReviewedBy")
  pointsLedgerActions       PointsLedger[]                  @relation("PointsLedgerActor")
  pointsAuditLogs           PointsAuditLog[]                @relation("PointsAuditActor")
  user          User      @relation(fields: [id], references: [id], onDelete: Cascade)

  @@index([nuId])
  @@index([isApproved])
  @@index([staffRole])
}

model Company {
  id           String    @id @default(uuid())
  userId       String    @unique
  name         String    @db.VarChar(200)
  categoryId   String?
  description  String?
  website      String?   @db.VarChar(255)
  contactEmail String?   @db.VarChar(255)
  contactPhone String?   @db.VarChar(20)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  category     Category? @relation(fields: [categoryId], references: [id])
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model FoodStall {
  id            String             @id @default(uuid())
  userId        String             @unique
  stallName     String             @db.VarChar(100)
  menuDetails   String?
  paymentStatus RegistrationStatus @default(PENDING_PAYMENT)
  stallLocation String?            @db.VarChar(100)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paymentStatus])
}

model BrandAmbassador {
  id             String   @id @default(uuid())
  userId         String   @unique
  fullName       String   @db.VarChar(100)
  institute      String   @db.VarChar(200)
  referralCode   String   @unique @db.VarChar(20)
  totalReferrals Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cnic           String   @unique @db.VarChar(15)
  phone          String?  @db.VarChar(20)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([referralCode])
  @@index([cnic])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  companies   Company[]
}

model TeamEmailsQueue {
  id               String   @id @default(uuid())
  teamMemberId     String    @unique   
  retryCount       Int       @default(0)
  failedReason     String?
  sendWelcome      Boolean  @default(true)
  sendRejection    Boolean  @default(false)
  sendAccept       Boolean  @default(false)
  sendOnHold       Boolean  @default(false)
  noteOnHold       String?
  noteRejection    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())
  teamMember       TeamMember @relation(fields: [teamMemberId], references: [id], onDelete:Cascade )
}
model Venue {
  id           String        @id @default(uuid())
  name         String        @db.VarChar(100)
  location     String?       @db.VarChar(200)
  capacity     Int?
  facilities   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  competitions Competition[] @relation("CompetitionToVenue")
}

/// Extra actions granted to a staff user by a super-admin.
/// Role-default actions are NOT stored here — they are derived at runtime.
model UserAction {
  id            String   @id @default(uuid())
  userId        String
  action        Action
  grantedAt     DateTime @default(now())
  grantedBy     String?
  grantedByUser User?    @relation("ActionGrantedBy", fields: [grantedBy], references: [id])
  user          User     @relation("UserGrantedActions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action])
  @@index([userId])
}

model Minigame {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String   @default("")
  isActive    Boolean  @default(true) @map("is_active")
  apiKeyHash  String?  @unique @map("api_key_hash")
  apiKeyPrefix String? @map("api_key_prefix")
  imageUrl    String?  @map("image_url")
  location    String?  @db.VarChar(200)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  scores Score[]
}

model Score {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userCode  String   @db.VarChar(20) @map("user_code")
  gameId    String   @db.Uuid @map("game_id")
  score     Float
  playTime  Float    @map("play_time")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  participant Participant @relation(fields: [userCode], references: [minigameCode], onDelete: Restrict, onUpdate: Cascade)
  game        Minigame    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userCode, gameId])
  @@index([gameId, score(sort: Desc), playTime(sort: Asc), updatedAt(sort: Desc)])
  @@index([gameId, updatedAt(sort: Desc)])
}

enum UserType {
  PARTICIPANT
  STAFF
  BRAND_AMBASSADOR
}

/// Roles for STAFF members only (portal permissions / responsibilities)
enum StaffRole {
  SUPERADMIN
  PR
  GR
  FOOD
  EXCOM
  COMPETITIONS
  AMBASSADOR_MANAGEMENT
}

enum RegistrationStatus {
  PENDING_PAYMENT
  VERIFIED
  FREE
  ONHOLD
  REJECTED
}

enum AttendanceMethod {
  SELF_GEOFENCE
  STAFF_QR
  STAFF_SOFT_MARK
}

enum PaymentMethod {
  BANK_TRANSFER
  EASYPAISA
  JAZZCASH
  CARD
  CASH
}

enum PointsLedgerEntryType {
  MANUAL_ACTIVITY
  ADJUSTMENT
}

enum PointsAuditActionType {
  ACTIVITY_TYPE_CREATED
  ACTIVITY_TYPE_UPDATED
  ACTIVITY_TYPE_TOGGLED
  ACTIVITY_COMPLETION_MARKED
  ACTIVITY_COMPLETION_REVOKED
  ACTIVITY_SUBMISSION_CREATED
  ACTIVITY_SUBMISSION_APPROVED
  ACTIVITY_SUBMISSION_REJECTED
  POINTS_ADJUSTED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Every discrete operation a portal user can perform.
enum Action {
  VIEW_REGISTRATION_DETAILS
  EDIT_COMPETITION
  VIEW_STALL_DETAILS
  ADD_NEW_STALL
  EDIT_STALL
  DELETE_STALL
  VIEW_ALL_COMPANIES
  ADD_NEW_COMPANY
  ASSIGN_BOOTH
  EDIT_COMPANY
  DELETE_COMPANY
  CREATE_NEW_REGISTRATION
  UPDATE_ATTENDANCE
  VIEW_ALL_PORTAL_USERS
  ASSIGN_ACTIONS_TO_USERS
  CREATE_ACCOUNTS
  UPDATE_PARTICIPANT_RECORD
  VIEW_AMBASSADOR_DASHBOARD
  MANAGE_AMBASSADORS
}
